# ==========================================
# ORQUESTRADOR DE INFRAESTRUTURA - FASE 3
# ==========================================

services:
  # ----------------------------------------
  # CAMADA DE DADOS: PostgreSQL
  # ----------------------------------------
  db:
    image: postgres:15-alpine
    container_name: medsched-db
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: ${POSTGRES_DB}
      TZ: America/Sao_Paulo
    ports:
      - "45432:5432"
    volumes:
      - medsched_db_data:/var/lib/postgresql/data
    networks:
      - medsched_net

  # ----------------------------------------
  # CAMADA LÓGICA: API Python (FastAPI)
  # ----------------------------------------
  api:
    build: 
      context: ./backend
      dockerfile: Dockerfile
    container_name: medsched-api
    # ----------------------------------------
    # 🔒 CORREÇÃO DE PERMISSÕES DO ALEMBIC
    # Garante que os arquivos gerados pertençam ao medicaluser (124:127)
    # ----------------------------------------
    user: "124:127"
    restart: unless-stopped
    ports:
      - "40000:8000"
    volumes:
      - ./backend:/app
    env_file:
      - .env
    depends_on:
      - db
    networks:
      - medsched_net

  # ----------------------------------------
  # CAMADA VISUAL: Frontend React (Vite)
  # ----------------------------------------
  web:
    build:
      context: ./frontend
      dockerfile: Dockerfile
    container_name: medsched-web
    restart: unless-stopped
    # Mapeamento: Porta 40001 no seu servidor -> Porta 3000 no container
    ports:
      - "40001:3000"
    volumes:
      - ./frontend:/app
      # Este volume anônimo impede que a pasta node_modules do container seja sobrescrita pelo host
      - /app/node_modules
    depends_on:
      - api
    networks:
      - medsched_net
# --- BANCO DE DADOS EM MEMÓRIA PARA O WHATSAPP ---
  redis:
    image: redis:7-alpine
    container_name: medsched-redis
    restart: always
    # Mapeando para porta alta (46379)
    ports:
      - "46379:6379"

  # --- A API DO WHATSAPP (EVOLUTION) ---
  whatsapp-api:
    image: evolution-api:2.1.1
    container_name: medsched-whatsapp
    restart: always
    environment:
      - SERVER_TYPE=http
      - SERVER_PORT=8080 # Interna do container permanece 8080
      - LOG_LEVEL=ERROR,WARN,DEBUG
      - DELAY_MESSAGES=true
      - DATABASE_ENABLED=false
      - REDIS_ENABLED=true
      - REDIS_URI=redis://redis:6379 # Comunicação interna entre containers (usa a porta original)
      - AUTHENTICATION_TYPE=apikey
      - AUTHENTICATION_API_KEY=medsched_global_secret_key
    ports:
      - "48080:8080" # Mapeando externa para porta alta (48080)
    depends_on:
      - redis
# ----------------------------------------
# VOLUMES PERSISTENTES
# ----------------------------------------
volumes:
  medsched_db_data:
    name: medsched_db_data

# ----------------------------------------
# REDES VIRTUAIS ISOLADAS
# ----------------------------------------
networks:
  medsched_net:
    name: medsched_net
    driver: bridge

from sqlalchemy.orm import Session
from sqlalchemy import cast, String, func  # 👇 DRCODE: Importado para forçar a busca exata
from uuid import UUID
from pydantic import ValidationError
from typing import List, Dict, Any
from datetime import datetime 

from src.models.import_staging import ImportBatch, ImportRow, ImportBatchStatus, ImportRowStatus, ImportEntityType
from src.schemas.import_staging import ImportBatchCreate

# Importações de Cliente
from src.models.customer import Customer
from src.schemas.customer import CustomerCreate

# Importações de Feriado
from src.models.holiday import Holiday
from src.schemas.holiday import HolidayCreate

# Importações do Fornecedor
from src.models.supplier import Supplier
from src.schemas.supplier import SupplierCreate

# ==========================================
# 1. FUNÇÕES DE CRIAÇÃO E LEITURA
# ==========================================
def create_import_batch(db: Session, obj_in: ImportBatchCreate) -> ImportBatch:
    agora = datetime.utcnow() 
    
    db_obj = ImportBatch(
        tenant_id=obj_in.tenant_id,
        user_id=obj_in.user_id,
        entity_type=obj_in.entity_type,
        file_name=obj_in.file_name,
        status=ImportBatchStatus.PENDING,
        criado_por=obj_in.user_id,
        alterado_por=obj_in.user_id,
        alterado_em=agora 
    )
    db.add(db_obj)
    db.commit()
    db.refresh(db_obj)
    return db_obj

def create_import_rows(db: Session, batch_id: UUID, rows_data: List[Dict[str, Any]]) -> None:
    rows_to_insert = []
    for index, row_data in enumerate(rows_data, start=1):
        rows_to_insert.append(
            ImportRow(
                batch_id=batch_id,
                row_number=index,
                raw_data=row_data,
                status=ImportRowStatus.PENDING
            )
        )
    db.add_all(rows_to_insert)
    
    batch = db.query(ImportBatch).filter(ImportBatch.id == batch_id).first()
    if batch:
        batch.total_rows = len(rows_to_insert)
        
    db.commit()

def get_batch(db: Session, batch_id: UUID, tenant_id: UUID):
    return db.query(ImportBatch).filter(ImportBatch.id == batch_id, ImportBatch.tenant_id == tenant_id).first()

# ==========================================
# 2. FUNÇÃO DE VALIDAÇÃO (INSPETOR)
# ==========================================
def validate_import_batch(db: Session, batch_id: UUID, tenant_id: UUID):
    batch = get_batch(db, batch_id, tenant_id)
    if not batch or batch.status != ImportBatchStatus.PENDING:
        return False

    batch.status = ImportBatchStatus.PROCESSING
    db.commit()

    rows = db.query(ImportRow).filter(ImportRow.batch_id == batch_id).all()
    valid_count = 0
    error_count = 0

    for row in rows:
        raw_lower = {k.lower().replace(" ", "_"): v for k, v in row.raw_data.items()}

        # ----------------------------------------------------
        # VALIDAÇÃO DE CLIENTES
        # ----------------------------------------------------
        if batch.entity_type == ImportEntityType.CUSTOMER:
            raw_nome = raw_lower.get("nome") or ""
            raw_email = raw_lower.get("email") or raw_lower.get("e-mail") or ""
            
            normalized_data = {
                "nome": str(raw_nome).strip(),
                "email": str(raw_email).strip(),
                "tenant_id": tenant_id
            }
            if raw_lower.get("telefone"): normalized_data["telefone"] = str(raw_lower.get("telefone")).strip()
            if raw_lower.get("cpf_cnpj"): normalized_data["cpf"] = str(raw_lower.get("cpf_cnpj")).strip()

            try:
                cust_in = CustomerCreate(**normalized_data)
                
                # 👇 DRCODE: Busca blindada por e-mail ignorando maiúsculas
                email_busca = str(cust_in.email).strip().lower()
                if db.query(Customer).filter(Customer.tenant_id == tenant_id, func.lower(Customer.email) == email_busca).first():
                    row.status = ImportRowStatus.DUPLICATED
                    row.error_message = f"E-mail '{email_busca}' já cadastrado no sistema."
                    error_count += 1
                else:
                    row.status = ImportRowStatus.VALID
                    row.error_message = None
                    row.raw_data = cust_in.model_dump(mode="json", exclude_unset=True)
                    valid_count += 1
            except ValidationError as e:
                row.status = ImportRowStatus.INVALID
                errors = [f"Campo '{err['loc'][0]}': {err['msg']}" for err in e.errors()]
                row.error_message = " | ".join(errors)
                error_count += 1

        # ----------------------------------------------------
        # VALIDAÇÃO DE FERIADOS
        # ----------------------------------------------------
        elif batch.entity_type == ImportEntityType.HOLIDAY:
            raw_nome = raw_lower.get("nome") or ""
            raw_data = raw_lower.get("data") or ""
            
            normalized_data = {
                "nome": str(raw_nome).strip(),
                "data": str(raw_data).strip(),
                "tenant_id": tenant_id
            }
            if raw_lower.get("tipo"): normalized_data["tipo"] = str(raw_lower.get("tipo")).strip().upper()
            if raw_lower.get("expediente"):
                val = str(raw_lower.get("expediente")).strip().lower()
                normalized_data["havera_expediente"] = val in ['sim', 's', 'true', '1']

            try:
                hol_in = HolidayCreate(**normalized_data)
                
                # 👇 DRCODE: Busca blindada ignorando horas invisíveis na base de dados
                data_busca = str(hol_in.data)[:10] # Pega estritamente o YYYY-MM-DD
                feriado_existente = db.query(Holiday).filter(
                    Holiday.tenant_id == tenant_id,
                    cast(Holiday.data, String).like(f"{data_busca}%")
                ).first()

                if feriado_existente:
                    row.status = ImportRowStatus.DUPLICATED
                    row.error_message = f"Feriado com a data {data_busca} já cadastrado."
                    error_count += 1
                else:
                    row.status = ImportRowStatus.VALID
                    row.error_message = None
                    row.raw_data = hol_in.model_dump(mode="json", exclude_unset=True)
                    valid_count += 1
            except ValidationError as e:
                row.status = ImportRowStatus.INVALID
                errors = [f"Campo '{err['loc'][0]}': {err['msg']}" for err in e.errors()]
                row.error_message = " | ".join(errors)
                error_count += 1

        # ----------------------------------------------------
        # VALIDAÇÃO DE FORNECEDORES
        # ----------------------------------------------------
        elif batch.entity_type == ImportEntityType.SUPPLIER:
            raw_razao = raw_lower.get("nome_razao") or raw_lower.get("razao_social") or raw_lower.get("razao") or ""
            raw_fantasia = raw_lower.get("nome_fantasia") or raw_lower.get("fantasia") or ""
            raw_cnpj = raw_lower.get("cnpj") or ""
            raw_email = raw_lower.get("email") or raw_lower.get("e-mail") or ""
            raw_telefone = raw_lower.get("telefone") or raw_lower.get("celular") or ""
            raw_contato = raw_lower.get("contato_nome") or raw_lower.get("contato") or ""

            normalized_data = {
                "nome_razao": str(raw_razao).strip(),
                "tenant_id": tenant_id
            }
            if str(raw_fantasia).strip(): normalized_data["nome_fantasia"] = str(raw_fantasia).strip()
            if str(raw_cnpj).strip(): normalized_data["cnpj"] = str(raw_cnpj).strip()
            if str(raw_email).strip(): normalized_data["email"] = str(raw_email).strip()
            if str(raw_telefone).strip(): normalized_data["telefone"] = str(raw_telefone).strip()
            if str(raw_contato).strip(): normalized_data["contato_nome"] = str(raw_contato).strip()
            
            try:
                supplier_in = SupplierCreate(**normalized_data)
                has_cnpj = bool(supplier_in.cnpj)
                has_email = bool(supplier_in.email)
                
                if not has_cnpj and not has_email:
                    row.status = ImportRowStatus.INVALID
                    row.error_message = "Obrigatório preencher CNPJ ou E-mail."
                    error_count += 1
                    db.add(row)
                    continue

                duplicate_errors = []
                if has_cnpj:
                    cnpj_busca = str(supplier_in.cnpj).strip()
                    if db.query(Supplier).filter(Supplier.tenant_id == tenant_id, cast(Supplier.cnpj, String).like(f"%{cnpj_busca}%")).first():
                        duplicate_errors.append(f"CNPJ '{cnpj_busca}' já cadastrado")
                        
                if has_email:
                    email_busca = str(supplier_in.email).strip().lower()
                    if db.query(Supplier).filter(Supplier.tenant_id == tenant_id, func.lower(Supplier.email) == email_busca).first():
                        duplicate_errors.append(f"E-mail '{email_busca}' já existe")

                if duplicate_errors:
                    row.status = ImportRowStatus.DUPLICATED
                    row.error_message = " | ".join(duplicate_errors)
                    error_count += 1
                    db.add(row)
                    continue

                row.status = ImportRowStatus.VALID
                row.error_message = None
                row.raw_data = supplier_in.model_dump(mode="json", exclude_unset=True)
                valid_count += 1

            except ValidationError as e:
                row.status = ImportRowStatus.INVALID
                errors = [f"Campo '{err['loc'][0]}': {err['msg']}" for err in e.errors()]
                row.error_message = " | ".join(errors)
                error_count += 1
                
        db.add(row)

    batch.valid_rows = valid_count
    batch.error_rows = error_count
    
    # 👇 DRCODE: Se houver qualquer erro, trava o botão de Promover e libera o Editar na UI
    #if error_count > 0:
    #    batch.status = ImportBatchStatus.PENDING
    #else:
    batch.status = ImportBatchStatus.VALIDATED
        
    db.commit()
    
    return batch

# ==========================================
# 3. FUNÇÃO DE PROMOÇÃO (INSERÇÃO FINAL)
# ==========================================
def promote_import_batch(db: Session, batch_id: UUID, tenant_id: UUID):
    batch = get_batch(db, batch_id, tenant_id)
    if not batch or batch.status != ImportBatchStatus.VALIDATED:
        return False, 0

    valid_rows = db.query(ImportRow).filter(ImportRow.batch_id == batch_id, ImportRow.status == ImportRowStatus.VALID).all()
    count = 0

    if not valid_rows:
        batch.status = ImportBatchStatus.COMPLETED
        db.commit()
        return True, 0

    if batch.entity_type == ImportEntityType.CUSTOMER:
        customers_to_insert = [Customer(**row.raw_data) for row in valid_rows]
        db.add_all(customers_to_insert)
        count = len(customers_to_insert)

    elif batch.entity_type == ImportEntityType.HOLIDAY:
        holidays_to_insert = [Holiday(**row.raw_data) for row in valid_rows]
        db.add_all(holidays_to_insert)
        count = len(holidays_to_insert)
        
    elif batch.entity_type == ImportEntityType.SUPPLIER:
        suppliers_to_insert = [Supplier(**row.raw_data) for row in valid_rows]
        db.add_all(suppliers_to_insert)
        count = len(suppliers_to_insert)

    for row in valid_rows:
        row.status = ImportRowStatus.PROMOTED

    batch.status = ImportBatchStatus.COMPLETED
    db.commit()

    return True, count
